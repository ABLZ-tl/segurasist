# =========================================================================
# SegurAsist API — variables de entorno (ver §14 doc Backend).
# Copia este archivo a `.env` y rellena con valores locales.
# Producción: estos valores vienen de AWS Secrets Manager / App Runner env.
# =========================================================================

# ---- Runtime ----
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug
TRACE_SAMPLE_RATE=0

# ---- Database (Postgres 16) ----
# Cliente normal del API (rol `segurasist_app`, NOBYPASSRLS).
DATABASE_URL=postgresql://segurasist:segurasist@localhost:5432/segurasist?schema=public

# Cliente cross-tenant para superadmin / writer auditoría (rol `segurasist_admin`,
# BYPASSRLS). Opcional en dev — si está ausente, los services superadmin lanzan
# NotImplementedException. En staging/prod: obligatorio para operar superadmin.
# Puede compartirse con DATABASE_URL_AUDIT (mismo rol BYPASSRLS).
# DATABASE_URL_BYPASS=postgresql://segurasist_admin:CHANGE_ME_IN_SECRETS_MANAGER@localhost:5432/segurasist?schema=public

# Writer de auditoría append-only. Si ausente: degradación a pino-only.
# DATABASE_URL_AUDIT=postgresql://segurasist_admin:CHANGE_ME_IN_SECRETS_MANAGER@localhost:5432/segurasist?schema=public

# ---- Cache (Redis 7) ----
REDIS_URL=redis://localhost:6379/0

# ---- AWS region + Cognito ----
AWS_REGION=mx-central-1
COGNITO_REGION=mx-central-1
COGNITO_USER_POOL_ID_ADMIN=mx-central-1_REPLACE
COGNITO_USER_POOL_ID_INSURED=mx-central-1_REPLACE
COGNITO_CLIENT_ID_ADMIN=REPLACE
COGNITO_CLIENT_ID_INSURED=REPLACE
# Override del endpoint Cognito para dev local (cognito-local).
# Si está presente, JwtAuthGuard arma issuer/JWKS contra esta base en lugar de
# `https://cognito-idp.<region>.amazonaws.com`. En prod: dejar vacío/comentado.
# COGNITO_ENDPOINT=http://localhost:9229

# ---- S3 buckets ----
S3_BUCKET_UPLOADS=segurasist-dev-uploads
S3_BUCKET_CERTIFICATES=segurasist-dev-certificates
# Sprint 2 S2-07: bucket inmutable (Object Lock COMPLIANCE 730d). En prod
# Sprint 5 reemplazado por bucket S3 mx-central-1 con misma config + replica
# us-east-1. El bucket legacy `*-audit` queda dedicado a backups de pg_dump.
S3_BUCKET_AUDIT=segurasist-dev-audit-v2
S3_BUCKET_EXPORTS=segurasist-dev-exports

# ---- SQS queues (URLs completas) ----
SQS_QUEUE_LAYOUT=http://localhost:4566/000000000000/layout-validation-queue
SQS_QUEUE_PDF=http://localhost:4566/000000000000/pdf-queue
SQS_QUEUE_EMAIL=http://localhost:4566/000000000000/email-queue
SQS_QUEUE_REPORTS=http://localhost:4566/000000000000/reports-queue
# Cola dedicada del InsuredsCreationWorker (post-confirm de batches). Standard
# (no FIFO); idempotencia DB-side vía UNIQUE (tenant_id, batch_id, row_number).
# DLQ + queue creadas en localstack-bootstrap.sh y Terraform de los 3 envs.
SQS_QUEUE_INSUREDS_CREATION=http://localhost:4566/000000000000/insureds-creation
# S4-04 — Cola del cron mensual (EventBridge → SQS). Standard, DLQ con
# maxReceiveCount=3, idempotencia DB-side `monthly_report_runs UNIQUE
# (tenant_id, period_year, period_month)`.
SQS_QUEUE_MONTHLY_REPORTS=http://localhost:4566/000000000000/monthly-reports

# S4-04 — Destinatarios del reporte mensual (CSV de emails). Mínimo 1.
MONTHLY_REPORT_RECIPIENTS=ops@segurasist.local,admin-mac@hospitalesmac.local

# ---- SES ----
SES_SENDER_DOMAIN=segurasist.local
SES_CONFIGURATION_SET=segurasist-dev

# ---- KMS ----
KMS_KEY_ID=alias/segurasist-dev

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ---- LocalStack (opcional, dev) ----
# AWS_ENDPOINT_URL=http://localhost:4566

# ---- Otros ----
ENABLE_SWAGGER=true

# ---- MFA enforcement ----
# Política de enforcement de MFA en JwtAuthGuard para roles admin.
# Valores: 'strict' | 'log' | 'off'.
# Default: 'strict' en NODE_ENV=production, 'log' en development/test/staging.
# cognito-local NO emite el claim `amr`, por eso el modo 'log' es el default
# fuera de prod. NUNCA usar 'off' en producción.
# MFA_ENFORCEMENT=log

# ---- Insureds Portal (S3-01) ----
# C-04 — OBLIGATORIA. Password compartida del pool Cognito de insureds que
# AuthService usa para AdminInitiateAuth tras verificar el OTP via Redis.
# Reglas:
#   - Mínimo 8 chars (siempre).
#   - En NODE_ENV=production: mínimo 14 chars + al menos un símbolo
#     no-alfanumérico. Hardcoded como `Demo123!` (default histórico) está
#     EXPLÍCITAMENTE bloqueado por superRefine en env.schema.ts.
#   - En prod, este valor SOLO debe leerse desde AWS Secrets Manager,
#     nunca desde un archivo .env.
# Generar dev: `openssl rand -base64 18 | tr -d '/+=' | head -c 20 ; echo '!'`.
INSURED_DEFAULT_PASSWORD=DevLocal-PleaseChange-9!

# ---- OTP (S3-01) ----
# OTP_TTL_SECONDS=300
# OTP_MAX_ATTEMPTS=5
# OTP_LOCKOUT_SECONDS=900

# ---- Email / SES adapter ----
# Override del transport. `smtp` apunta a Mailpit (SMTP_HOST:SMTP_PORT).
# `aws` usa SES real. Default: smtp en dev/test, aws en staging/prod.
# EMAIL_TRANSPORT=smtp
# SMTP_HOST=localhost
# SMTP_PORT=1025

# Base URL pública del API (incrustada en QR de certificados).
# CERT_BASE_URL=http://localhost:3000

# From de los emails de certificado (override por tenant si está set).
# EMAIL_FROM_CERT=cert@segurasist.app

# Mailpit API URL (re-emisión a demanda + tracking, solo dev).
# MAILPIT_API_URL=http://localhost:8025

# ---- Chatbot escalation (S4-08) ----
# Inbox del equipo MAC para escalamientos human-in-the-loop. En dev apunta a
# Mailpit; en prod debe ser una DL gestionada por MAC (e.g. soporte@mac.com.mx).
# MAC_SUPPORT_EMAIL=mac-support@segurasist.local
