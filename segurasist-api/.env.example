# =========================================================================
# SegurAsist API — variables de entorno (ver §14 doc Backend).
# Copia este archivo a `.env` y rellena con valores locales.
# Producción: estos valores vienen de AWS Secrets Manager / App Runner env.
# =========================================================================

# ---- Runtime ----
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug
TRACE_SAMPLE_RATE=0

# ---- Database (Postgres 16) ----
DATABASE_URL=postgresql://segurasist:segurasist@localhost:5432/segurasist?schema=public

# ---- Cache (Redis 7) ----
REDIS_URL=redis://localhost:6379/0

# ---- AWS region + Cognito ----
AWS_REGION=mx-central-1
COGNITO_REGION=mx-central-1
COGNITO_USER_POOL_ID_ADMIN=mx-central-1_REPLACE
COGNITO_USER_POOL_ID_INSURED=mx-central-1_REPLACE
COGNITO_CLIENT_ID_ADMIN=REPLACE
COGNITO_CLIENT_ID_INSURED=REPLACE
# Override del endpoint Cognito para dev local (cognito-local).
# Si está presente, JwtAuthGuard arma issuer/JWKS contra esta base en lugar de
# `https://cognito-idp.<region>.amazonaws.com`. En prod: dejar vacío/comentado.
# COGNITO_ENDPOINT=http://localhost:9229

# ---- S3 buckets ----
S3_BUCKET_UPLOADS=segurasist-dev-uploads
S3_BUCKET_CERTIFICATES=segurasist-dev-certificates
S3_BUCKET_AUDIT=segurasist-dev-audit
S3_BUCKET_EXPORTS=segurasist-dev-exports

# ---- SQS queues (URLs completas) ----
SQS_QUEUE_LAYOUT=http://localhost:4566/000000000000/layout-validation-queue
SQS_QUEUE_PDF=http://localhost:4566/000000000000/pdf-queue
SQS_QUEUE_EMAIL=http://localhost:4566/000000000000/email-queue
SQS_QUEUE_REPORTS=http://localhost:4566/000000000000/reports-queue

# ---- SES ----
SES_SENDER_DOMAIN=segurasist.local
SES_CONFIGURATION_SET=segurasist-dev

# ---- KMS ----
KMS_KEY_ID=alias/segurasist-dev

# ---- CORS ----
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ---- LocalStack (opcional, dev) ----
# AWS_ENDPOINT_URL=http://localhost:4566

# ---- Otros ----
ENABLE_SWAGGER=true
