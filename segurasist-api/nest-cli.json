{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      { "include": "modules/certificates/templates/**/*.hbs", "outDir": "dist" },
      { "include": "modules/email/templates/**/*.hbs", "outDir": "dist" }
    ],
    "watchAssets": true
  }
}
