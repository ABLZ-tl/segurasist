{
  "name": "segurasist-api",
  "version": "0.1.0",
  "description": "SegurAsist API — NestJS 10 + Fastify + Prisma + PostgreSQL 16 (multi-tenant SaaS)",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0 <21",
    "npm": ">=10.0.0"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "NODE_ENV=development nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings=25",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test,prisma}/**/*.{ts,json}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest --config jest.config.ts --selectProjects unit",
    "test:integration": "jest --config jest.config.ts --selectProjects integration --runInBand",
    "test:cross-tenant": "jest --config jest.config.ts --selectProjects security --runInBand",
    "test:e2e": "jest --config jest.config.ts --selectProjects e2e --runInBand",
    "test:cov": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prepare": "echo 'skip husky in CI'"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "3.621.0",
    "@aws-sdk/client-kms": "3.621.0",
    "@aws-sdk/client-s3": "3.621.0",
    "@aws-sdk/client-secrets-manager": "3.621.0",
    "@aws-sdk/client-ses": "3.621.0",
    "@aws-sdk/client-sqs": "3.621.0",
    "@aws-sdk/s3-request-presigner": "3.621.0",
    "@fastify/compress": "7.0.3",
    "@fastify/cors": "9.0.1",
    "@fastify/helmet": "11.1.1",
    "@fastify/multipart": "8.3.0",
    "@nestjs/common": "10.4.4",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "10.4.4",
    "@nestjs/platform-fastify": "10.4.4",
    "@nestjs/terminus": "10.2.3",
    "@prisma/client": "5.19.1",
    "aws-xray-sdk-core": "3.9.0",
    "exceljs": "^4.4.0",
    "fastify": "4.28.1",
    "handlebars": "4.7.8",
    "ioredis": "5.4.1",
    "jose": "5.9.2",
    "nestjs-pino": "4.1.0",
    "nodemailer": "6.9.15",
    "papaparse": "5.4.1",
    "pino": "9.4.0",
    "pino-http": "10.3.0",
    "pino-pretty": "11.2.2",
    "puppeteer": "22.15.0",
    "qrcode": "1.5.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "uuid": "10.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.5",
    "@nestjs/schematics": "10.1.4",
    "@nestjs/testing": "10.4.4",
    "@types/jest": "29.5.13",
    "@types/node": "20.16.5",
    "@types/nodemailer": "6.4.16",
    "@types/papaparse": "5.3.14",
    "@types/qrcode": "1.5.5",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.6.0",
    "@typescript-eslint/parser": "8.6.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.30.0",
    "eslint-plugin-prettier": "5.2.1",
    "jest": "29.7.0",
    "jest-mock-extended": "^4.0.1",
    "prettier": "3.3.3",
    "prisma": "5.19.1",
    "supertest": "7.0.0",
    "testcontainers": "10.13.1",
    "ts-jest": "29.2.5",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.4.5"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
