// SegurAsist — Prisma schema
// Multi-tenant. Cada tabla (excepto Tenant) lleva tenant_id NOT NULL.
// RLS PostgreSQL: las migraciones de Prisma sólo crean el schema. El
// bootstrap de roles + políticas vive en `prisma/rls/policies.sql` y se
// aplica con `./scripts/apply-rls.sh` después de `prisma migrate deploy`.
// Ver `docs/LOCAL_DEV.md`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum TenantStatus {
  active
  suspended
  archived

  @@map("tenant_status")
}

enum UserRole {
  admin_segurasist
  admin_mac
  operator
  supervisor
  insured

  @@map("user_role")
}

enum UserStatus {
  active
  invited
  disabled

  @@map("user_status")
}

enum PackageStatus {
  active
  archived

  @@map("package_status")
}

enum CoverageType {
  consultation
  emergency
  hospitalization
  laboratory
  imaging
  pharmacy
  other

  @@map("coverage_type")
}

enum InsuredStatus {
  active
  suspended
  cancelled
  expired

  @@map("insured_status")
}

enum BeneficiaryRelationship {
  spouse
  child
  parent
  sibling
  other

  @@map("beneficiary_relationship")
}

enum CertificateStatus {
  issued
  reissued
  revoked

  @@map("certificate_status")
}

enum ClaimStatus {
  reported
  in_review
  approved
  rejected
  paid

  @@map("claim_status")
}

enum ClaimType {
  consultation
  emergency
  hospitalization
  laboratory
  imaging
  pharmacy
  other

  @@map("claim_type")
}

enum BatchStatus {
  validating
  preview_ready
  processing
  completed
  failed
  cancelled

  @@map("batch_status")
}

enum EmailEventType {
  queued
  sent
  delivered
  bounced
  complained
  opened
  clicked
  rejected

  @@map("email_event_type")
}

enum ChatDirection {
  inbound
  outbound

  @@map("chat_direction")
}

enum ChatKbStatus {
  draft
  published
  archived

  @@map("chat_kb_status")
}

/// H-01 / P3 — enum extendido para acabar con el "overload" de `login`/`read`
/// como semánticas múltiples (OTP request, OTP verify, certificate view,
/// certificate download, export download). Antes había callers
/// (auth.service.ts:233/318, certificates.service.ts:225, insureds.service.ts)
/// codificando el sub-action dentro de `payloadDiff.subAction='viewed_360'` o
/// `resourceType='auth.otp.requested'` — drift y queries imposibles
/// (e.g. "todas las descargas de un mes").
///
/// Valores agregados:
///   - otp_requested / otp_verified  → flow OTP del portal (auth.service)
///   - read_viewed                  → vista 360, single resource read tracked
///   - read_downloaded              → presigned URL emitido (PII pasa por
///                                    nuestros servers vía signed URL)
///   - export_downloaded            → user descargó un export PII previamente
///                                    generado (NO es la generación, eso es `export`)
///
/// Migración (`20260428_audit_action_enum_extend`) usa
/// `ALTER TYPE ... ADD VALUE IF NOT EXISTS` — Postgres soporta agregar
/// valores enum desde la 12+ sin downtime. Filas existentes con `login` que
/// representaban OTP no se re-escriben automáticamente: los tests de
/// regresión solo verifican que las nuevas escrituras usan los valores
/// correctos. Migración a los nuevos valores en services es iter 2 (F6).
enum AuditAction {
  create
  update
  delete
  read
  login
  logout
  export
  reissue
  otp_requested
  otp_verified
  read_viewed
  read_downloaded
  export_downloaded

  @@map("audit_action")
}

/// S3-09 — Estado del job asíncrono de export. Transiciones legales:
///   pending → processing → ready
///   pending → processing → failed
/// El worker no permite retroceder estados; un job failed se descarta
/// (el user puede re-disparar uno nuevo).
enum ExportStatus {
  pending
  processing
  ready
  failed

  @@map("export_status")
}

// ============== MODELS ==============

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @db.VarChar(160)
  slug      String       @unique @db.VarChar(80)
  status    TenantStatus @default(active)
  brandJson Json?        @map("brand_json")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  users         User[]
  packages      Package[]
  coverages     Coverage[]
  insureds      Insured[]
  beneficiaries Beneficiary[]
  certificates  Certificate[]
  claims        Claim[]
  usages        CoverageUsage[]
  batches       Batch[]
  batchErrors   BatchError[]
  emailEvents   EmailEvent[]
  chatMessages  ChatMessage[]
  chatKb        ChatKb[]
  auditLogs     AuditLog[]
  exports       Export[]

  @@index([status])
  @@map("tenants")
}

/// User multi-tenant.
/// `tenantId` es NULLABLE para soportar superadmin (`role=admin_segurasist`)
/// que opera cross-tenant. La integridad la garantiza un CHECK constraint
/// instalado por la migración `20260426_superadmin_nullable_tenant`:
///
///   CHECK ((tenant_id IS NULL AND role IN ('admin_segurasist'))
///          OR (tenant_id IS NOT NULL))
///
/// Es decir: solo los superadmins pueden tener `tenant_id NULL`. Cualquier
/// otro rol DEBE traer un tenant. RLS bypass del superadmin se hace al nivel
/// de rol DB (`segurasist_admin` con BYPASSRLS) — ver `prisma-bypass-rls.service.ts`.
model User {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String?    @map("tenant_id") @db.Uuid
  cognitoSub  String     @map("cognito_sub") @db.VarChar(64)
  email       String     @db.VarChar(254)
  fullName    String     @map("full_name") @db.VarChar(160)
  role        UserRole
  mfaEnrolled Boolean    @default(false) @map("mfa_enrolled")
  status      UserStatus @default(invited)
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email], name: "user_tenant_email_unique")
  @@unique([cognitoSub], name: "user_cognito_sub_unique")
  @@index([tenantId, role])
  @@index([tenantId, status])
  @@map("users")
}

model Package {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String        @db.VarChar(120)
  description String?       @db.Text
  status      PackageStatus @default(active)
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  coverages Coverage[]
  insureds  Insured[]

  @@unique([tenantId, name], name: "package_tenant_name_unique")
  @@index([tenantId, status])
  @@map("packages")
}

model Coverage {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  packageId   String       @map("package_id") @db.Uuid
  name        String       @db.VarChar(120)
  type        CoverageType
  limitCount  Int?         @map("limit_count")
  limitAmount Decimal?     @map("limit_amount") @db.Decimal(12, 2)
  copayment   Decimal?     @db.Decimal(12, 2)
  description String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  package Package         @relation(fields: [packageId], references: [id])
  usages  CoverageUsage[]

  @@index([tenantId, packageId])
  @@index([tenantId, type])
  @@map("coverages")
}

model Insured {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @map("tenant_id") @db.Uuid
  curp      String        @db.VarChar(18)
  rfc       String?       @db.VarChar(13)
  fullName  String        @map("full_name") @db.VarChar(160)
  dob       DateTime      @db.Date
  email     String?       @db.VarChar(254)
  phone     String?       @db.VarChar(20)
  /// Cognito sub del insured pool. Nullable hasta que el flow OTP del Sprint 3
  /// popule el campo en el primer login (post-verify). Unique para evitar
  /// que dos insureds compartan identidad federada.
  cognitoSub String?      @unique @map("cognito_sub") @db.VarChar(64)
  packageId String        @map("package_id") @db.Uuid
  validFrom DateTime      @map("valid_from") @db.Date
  validTo   DateTime      @map("valid_to") @db.Date
  status    InsuredStatus @default(active)
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  package       Package         @relation(fields: [packageId], references: [id])
  beneficiaries Beneficiary[]
  certificates  Certificate[]
  claims        Claim[]
  usages        CoverageUsage[]

  @@unique([tenantId, curp], name: "insured_tenant_curp_unique")
  @@index([tenantId, status])
  @@index([tenantId, packageId])
  @@index([tenantId, validTo])
  @@map("insureds")
}

model Beneficiary {
  id           String                  @id @default(uuid()) @db.Uuid
  tenantId     String                  @map("tenant_id") @db.Uuid
  insuredId    String                  @map("insured_id") @db.Uuid
  fullName     String                  @map("full_name") @db.VarChar(160)
  relationship BeneficiaryRelationship
  dob          DateTime                @db.Date
  curp         String?                 @db.VarChar(18)
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  deletedAt    DateTime?               @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  insured Insured @relation(fields: [insuredId], references: [id])

  @@index([tenantId, insuredId])
  @@map("beneficiaries")
}

model Certificate {
  id        String            @id @default(uuid()) @db.Uuid
  tenantId  String            @map("tenant_id") @db.Uuid
  insuredId String            @map("insured_id") @db.Uuid
  version   Int               @default(1)
  s3Key     String            @map("s3_key") @db.VarChar(512)
  hash      String            @db.VarChar(128)
  qrPayload String            @map("qr_payload") @db.VarChar(512)
  issuedAt  DateTime          @default(now()) @map("issued_at")
  validTo   DateTime          @map("valid_to") @db.Date
  status    CertificateStatus @default(issued)
  reissueOf String?           @map("reissue_of") @db.Uuid
  reason    String?           @db.Text
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  deletedAt DateTime?         @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  insured Insured @relation(fields: [insuredId], references: [id])

  @@unique([tenantId, insuredId, version], name: "cert_tenant_insured_version_unique")
  @@index([tenantId, insuredId])
  @@index([tenantId, status])
  @@map("certificates")
}

model Claim {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  insuredId       String      @map("insured_id") @db.Uuid
  type            ClaimType
  reportedAt      DateTime    @default(now()) @map("reported_at")
  description     String      @db.Text
  status          ClaimStatus @default(reported)
  amountEstimated Decimal?    @map("amount_estimated") @db.Decimal(12, 2)
  amountApproved  Decimal?    @map("amount_approved") @db.Decimal(12, 2)
  resolvedAt      DateTime?   @map("resolved_at")
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  insured Insured @relation(fields: [insuredId], references: [id])

  @@index([tenantId, insuredId])
  @@index([tenantId, status])
  @@index([tenantId, reportedAt(sort: Desc)])
  @@map("claims")
}

model CoverageUsage {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  insuredId  String   @map("insured_id") @db.Uuid
  coverageId String   @map("coverage_id") @db.Uuid
  usedAt     DateTime @default(now()) @map("used_at")
  amount     Decimal? @db.Decimal(12, 2)
  source     String   @db.VarChar(40)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  insured  Insured  @relation(fields: [insuredId], references: [id])
  coverage Coverage @relation(fields: [coverageId], references: [id])

  @@index([tenantId, insuredId])
  @@index([tenantId, coverageId])
  @@index([tenantId, usedAt(sort: Desc)])
  @@map("coverage_usage")
}

model Batch {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  fileS3Key   String      @map("file_s3_key") @db.VarChar(512)
  fileName    String      @map("file_name") @db.VarChar(255)
  status      BatchStatus @default(validating)
  /// Counters fase VALIDATION (LayoutWorker / sync upload). NO los pisa el
  /// InsuredsCreationWorker — el worker tiene sus propios contadores
  /// (`processedRows`, `successRows`, `failedRows`).
  rowsTotal   Int         @default(0) @map("rows_total")
  rowsOk      Int         @default(0) @map("rows_ok")
  rowsError   Int         @default(0) @map("rows_error")
  /// Counters fase PROCESSING (InsuredsCreationWorker). Se setean en `confirm()`
  /// reseteados a 0 y se incrementan atómicamente por el worker. Cuando
  /// `processedRows >= queuedCount` el batch transiciona a `completed`.
  processedRows Int       @default(0) @map("processed_rows")
  successRows   Int       @default(0) @map("success_rows")
  failedRows    Int       @default(0) @map("failed_rows")
  /// Número real de mensajes encolados al confirmar (puede ser subset de
  /// `rowsOk` si `confirm()` recibió `rowsToInclude`). Comparar contadores
  /// del worker contra esto, NO contra `rowsTotal`.
  queuedCount Int?        @map("queued_count")
  createdBy   String      @map("created_by") @db.Uuid
  startedAt   DateTime?   @map("started_at")
  completedAt DateTime?   @map("completed_at")
  /// Defensa exactly-once para `batch.completed`. Set vía UPDATE atómico
  /// `WHERE completed_event_emitted_at IS NULL`; solo un caller gana la
  /// carrera y emite el evento. UNIQUE index parcial backup en migración.
  completedEventEmittedAt DateTime? @map("completed_event_emitted_at") @db.Timestamptz
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  errors BatchError[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("batches")
}

model BatchError {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  batchId      String   @map("batch_id") @db.Uuid
  rowNumber    Int      @map("row_number")
  column       String?  @db.VarChar(80)
  errorCode    String   @map("error_code") @db.VarChar(64)
  errorMessage String   @map("error_message") @db.Text
  rawValue     String?  @map("raw_value") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  batch  Batch  @relation(fields: [batchId], references: [id])

  @@index([tenantId, batchId])
  @@map("batch_errors")
}

model EmailEvent {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  certificateId String?        @map("certificate_id") @db.Uuid
  eventType     EmailEventType @map("event_type")
  recipient     String         @db.VarChar(254)
  occurredAt    DateTime       @default(now()) @map("occurred_at")
  detail        Json?
  messageId     String?        @map("message_id") @db.VarChar(255)
  createdAt     DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, certificateId])
  @@index([tenantId, eventType])
  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("email_events")
}

model ChatMessage {
  id         String        @id @default(uuid()) @db.Uuid
  tenantId   String        @map("tenant_id") @db.Uuid
  insuredId  String?       @map("insured_id") @db.Uuid
  direction  ChatDirection
  content    String        @db.Text
  intent     String?       @db.VarChar(80)
  confidence Float?
  escalated  Boolean       @default(false)
  createdAt  DateTime      @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, insuredId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("chat_messages")
}

model ChatKb {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  category  String       @db.VarChar(80)
  question  String       @db.Text
  answer    String       @db.Text
  version   Int          @default(1)
  status    ChatKbStatus @default(draft)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, category])
  @@index([tenantId, status])
  @@map("chat_kb")
}

/// Alertas operativas (P2/P3). En MVP se usa para bounce_rate>5% diario en
/// email — no bloquea envíos, sólo notifica para que ops revise. Modelo
/// deliberadamente simple: no hay multi-tenant por defecto (alertas globales
/// SegurAsist) pero `tenantId` es opcional para alertas tenant-specific.
model SystemAlert {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String?   @map("tenant_id") @db.Uuid
  severity   String    @db.VarChar(16) // 'P1' | 'P2' | 'P3'
  code       String    @db.VarChar(64)
  message    String    @db.Text
  context    Json?
  occurredAt DateTime  @default(now()) @map("occurred_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([severity, occurredAt(sort: Desc)])
  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("system_alerts")
}

model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  actorId      String?     @map("actor_id") @db.Uuid
  action       AuditAction
  resourceType String      @map("resource_type") @db.VarChar(80)
  resourceId   String?     @map("resource_id") @db.VarChar(80)
  ip           String?     @db.VarChar(45)
  userAgent    String?     @map("user_agent") @db.VarChar(500)
  payloadDiff  Json?       @map("payload_diff")
  traceId      String?     @map("trace_id") @db.VarChar(64)
  occurredAt   DateTime    @default(now()) @map("occurred_at")
  /// Hash chain — `prev_hash` apunta al `row_hash` de la fila anterior por
  /// tenant. La primera fila usa `'0' * 64` como génesis. `row_hash` es
  /// SHA-256 de `prev_hash || tenantId || actorId || action || resourceType
  /// || resourceId || JSON canónico(payloadDiff) || occurredAt.toISOString()`.
  /// Tampering detection: `GET /v1/audit/verify-chain` recomputa la cadena.
  prevHash     String      @map("prev_hash") @db.Char(64)
  rowHash      String      @map("row_hash") @db.Char(64)
  /// Mirror inmutable a S3 (Sprint 2 — S2-07). `mirroredToS3` arranca FALSE;
  /// `AuditS3MirrorService` corre cada minuto, agrupa por (tenant, día), sube
  /// NDJSON al bucket Object Lock COMPLIANCE 730d y marca las filas como
  /// mirrored. Si LocalStack/S3 está down: graceful retry — la fila vuelve a
  /// caer en el batch siguiente (mirrored_to_s3 sigue false hasta success).
  mirroredToS3 Boolean     @default(false) @map("mirrored_to_s3")
  mirroredAt   DateTime?   @map("mirrored_at") @db.Timestamp(3)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, actorId])
  @@map("audit_log")
}

/// S3-09 — Job asíncrono de exportación XLSX/PDF de listados (insureds).
///
/// Lifecycle:
///   1. Controller persiste fila con `status='pending'`, encola SQS
///      `reports-queue` y devuelve `{exportId}` al cliente.
///   2. Worker (`ReportsWorkerService`) leee SQS, marca `status='processing'`,
///      genera el archivo, sube a S3 (SSE-KMS), calcula SHA-256, persiste
///      `s3_key`, `hash`, `row_count` y marca `status='ready'`.
///   3. Cliente polea `GET /v1/exports/:id`; cuando `ready`, recibe
///      `downloadUrl` (presigned 24h) + `expiresAt`.
///
/// Anti-abuso (PII):
///   - Rate limit a nivel controller (1/min por user; 10/día por tenant).
///   - Audit log obligatorio en request + completed.
///   - Filename excluye IDs internos (cognito_sub, exportId).
///   - Hash SHA-256 persistido para verificar integridad post-descarga.
///
/// Lectura: el endpoint GET filtra adicionalmente por `requested_by = user.id`
/// (cada user sólo ve sus propios exports). Los superadmins pueden inspeccionar
/// cross-user vía `PrismaBypassRlsService` (no expuesto en MVP).
model Export {
  id          String       @id @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  requestedBy String       @map("requested_by") @db.Uuid
  /// Tipo de export. En MVP sólo `insureds`. CHECK constraint en migración.
  kind        String       @db.Text
  /// Formato de salida. CHECK constraint en migración (xlsx | pdf).
  format      String       @db.Text
  /// Snapshot inmutable de los filtros aplicados. Reproducibilidad + forensics.
  filters     Json         @default("{}")
  status      ExportStatus @default(pending)
  rowCount    Int?         @map("row_count")
  s3Key       String?      @map("s3_key") @db.Text
  /// SHA-256 hex del archivo final. Permite que el cliente valide integridad
  /// recomputando contra el archivo descargado.
  hash        String?      @db.Text
  error       String?      @db.Text
  requestedAt DateTime     @default(now()) @map("requested_at") @db.Timestamptz(3)
  completedAt DateTime?    @map("completed_at") @db.Timestamptz(3)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status], map: "exports_tenant_status_idx")
  @@index([tenantId, requestedBy, requestedAt(sort: Desc)], map: "exports_requester_idx")
  @@index([tenantId, requestedAt(sort: Desc)], map: "exports_tenant_requested_at_idx")
  @@map("exports")
}
