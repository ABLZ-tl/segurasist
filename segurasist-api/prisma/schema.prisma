// SegurAsist — Prisma schema
// Multi-tenant. Cada tabla (excepto Tenant) lleva tenant_id NOT NULL.
// RLS PostgreSQL: las migraciones de Prisma sólo crean el schema. El
// bootstrap de roles + políticas vive en `prisma/rls/policies.sql` y se
// aplica con `./scripts/apply-rls.sh` después de `prisma migrate deploy`.
// Ver `docs/LOCAL_DEV.md`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============

enum TenantStatus {
  active
  suspended
  archived

  @@map("tenant_status")
}

enum UserRole {
  admin_segurasist
  admin_mac
  operator
  supervisor
  insured

  @@map("user_role")
}

enum UserStatus {
  active
  invited
  disabled

  @@map("user_status")
}

enum PackageStatus {
  active
  archived

  @@map("package_status")
}

enum CoverageType {
  consultation
  emergency
  hospitalization
  laboratory
  imaging
  pharmacy
  other

  @@map("coverage_type")
}

enum InsuredStatus {
  active
  suspended
  cancelled
  expired

  @@map("insured_status")
}

enum BeneficiaryRelationship {
  spouse
  child
  parent
  sibling
  other

  @@map("beneficiary_relationship")
}

enum CertificateStatus {
  issued
  reissued
  revoked

  @@map("certificate_status")
}

enum ClaimStatus {
  reported
  in_review
  approved
  rejected
  paid

  @@map("claim_status")
}

enum ClaimType {
  consultation
  emergency
  hospitalization
  laboratory
  imaging
  pharmacy
  other

  @@map("claim_type")
}

enum BatchStatus {
  validating
  preview_ready
  processing
  completed
  failed
  cancelled

  @@map("batch_status")
}

enum EmailEventType {
  queued
  sent
  delivered
  bounced
  complained
  opened
  clicked
  rejected

  @@map("email_event_type")
}

enum ChatDirection {
  inbound
  outbound

  @@map("chat_direction")
}

enum ChatKbStatus {
  draft
  published
  archived

  @@map("chat_kb_status")
}

/// S4-06 — Estado de una conversación con el chatbot.
///   active    → mensajes nuevos siguen apareciendo en este conversation row.
///   escalated → el matcher no encontró respuesta (o keyword 'agente'); el
///               cliente recibió mensaje de derivación. Lo cierra el operator.
///   closed    → conversación archivada (timeout cron 24h sin actividad o
///               cierre explícito).
enum ChatConversationStatus {
  active
  escalated
  closed

  @@map("chat_conversation_status")
}

/// H-01 / P3 — enum extendido para acabar con el "overload" de `login`/`read`
/// como semánticas múltiples (OTP request, OTP verify, certificate view,
/// certificate download, export download). Antes había callers
/// (auth.service.ts:233/318, certificates.service.ts:225, insureds.service.ts)
/// codificando el sub-action dentro de `payloadDiff.subAction='viewed_360'` o
/// `resourceType='auth.otp.requested'` — drift y queries imposibles
/// (e.g. "todas las descargas de un mes").
///
/// Valores agregados:
///   - otp_requested / otp_verified  → flow OTP del portal (auth.service)
///   - read_viewed                  → vista 360, single resource read tracked
///   - read_downloaded              → presigned URL emitido (PII pasa por
///                                    nuestros servers vía signed URL)
///   - export_downloaded            → user descargó un export PII previamente
///                                    generado (NO es la generación, eso es `export`)
///
/// Migraciones aplicables:
///   - `20260428_audit_action_enum_extend` (Sprint 3 H-01): otp_requested,
///     otp_verified, read_viewed, read_downloaded, export_downloaded.
///   - `20260429_audit_action_sprint4_extend` (Sprint 4 S10 NEW-FINDING-S10-03):
///     chatbot_message_sent (S5), chatbot_escalated (S6), report_generated (S1),
///     report_downloaded (S1), monthly_report_sent (S3 cron).
///
/// Las migraciones usan `ALTER TYPE ... ADD VALUE IF NOT EXISTS` — Postgres
/// soporta agregar valores enum desde la 12+ sin downtime. Filas existentes
/// con el workaround previo (`action='create'`+`resourceType='chatbot.message'`,
/// `action='update'`+`payloadDiff.subAction='escalated'`) NO se re-escriben
/// automáticamente: los services migran a los nuevos valores en sus iter 2
/// respectivos. S5 ya migró en este iter (KbService.processMessage); S1, S3
/// y S6 quedan en backlog del feed (los enum values ya existen, solo cambia
/// el caller).
enum AuditAction {
  create
  update
  delete
  read
  login
  logout
  export
  reissue
  otp_requested
  otp_verified
  read_viewed
  read_downloaded
  export_downloaded
  // Sprint 4 — S10 NEW-FINDING-S10-03 + S5 iter 2 follow-up.
  chatbot_message_sent
  chatbot_escalated
  report_generated
  report_downloaded
  monthly_report_sent

  @@map("audit_action")
}

/// S3-09 — Estado del job asíncrono de export. Transiciones legales:
///   pending → processing → ready
///   pending → processing → failed
/// El worker no permite retroceder estados; un job failed se descarta
/// (el user puede re-disparar uno nuevo).
enum ExportStatus {
  pending
  processing
  ready
  failed

  @@map("export_status")
}

/// S4-04 — Estado del cron mensual por tenant.
///   pending → processing → completed
///   pending → processing → failed
/// `completed` significa: PDF generado + email enviado + audit log. La
/// transición a `failed` deja el run para inspección on-call (NO se reintenta
/// automáticamente al re-recibir el cron — la UNIQUE bloquea).
enum MonthlyReportStatus {
  pending
  processing
  completed
  failed

  @@map("monthly_report_status")
}

// ============== MODELS ==============

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String       @db.VarChar(160)
  slug      String       @unique @db.VarChar(80)
  status    TenantStatus @default(active)
  brandJson Json?        @map("brand_json")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  users         User[]
  packages      Package[]
  coverages     Coverage[]
  insureds      Insured[]
  beneficiaries Beneficiary[]
  certificates  Certificate[]
  claims        Claim[]
  usages        CoverageUsage[]
  batches       Batch[]
  batchErrors   BatchError[]
  emailEvents   EmailEvent[]
  chatMessages  ChatMessage[]
  chatConversations ChatConversation[]
  chatKb        ChatKb[]
  auditLogs     AuditLog[]
  exports       Export[]
  monthlyReportRuns MonthlyReportRun[]

  @@index([status])
  @@map("tenants")
}

/// User multi-tenant.
/// `tenantId` es NULLABLE para soportar superadmin (`role=admin_segurasist`)
/// que opera cross-tenant. La integridad la garantiza un CHECK constraint
/// instalado por la migración `20260426_superadmin_nullable_tenant`:
///
///   CHECK ((tenant_id IS NULL AND role IN ('admin_segurasist'))
///          OR (tenant_id IS NOT NULL))
///
/// Es decir: solo los superadmins pueden tener `tenant_id NULL`. Cualquier
/// otro rol DEBE traer un tenant. RLS bypass del superadmin se hace al nivel
/// de rol DB (`segurasist_admin` con BYPASSRLS) — ver `prisma-bypass-rls.service.ts`.
model User {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String?    @map("tenant_id") @db.Uuid
  cognitoSub  String     @map("cognito_sub") @db.VarChar(64)
  email       String     @db.VarChar(254)
  fullName    String     @map("full_name") @db.VarChar(160)
  role        UserRole
  mfaEnrolled Boolean    @default(false) @map("mfa_enrolled")
  status      UserStatus @default(invited)
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email], name: "user_tenant_email_unique")
  @@unique([cognitoSub], name: "user_cognito_sub_unique")
  @@index([tenantId, role])
  @@index([tenantId, status])
  @@map("users")
}

model Package {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  name        String        @db.VarChar(120)
  description String?       @db.Text
  status      PackageStatus @default(active)
  metadata    Json?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  coverages Coverage[]
  insureds  Insured[]

  @@unique([tenantId, name], name: "package_tenant_name_unique")
  @@index([tenantId, status])
  @@map("packages")
}

model Coverage {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  packageId   String       @map("package_id") @db.Uuid
  name        String       @db.VarChar(120)
  type        CoverageType
  limitCount  Int?         @map("limit_count")
  limitAmount Decimal?     @map("limit_amount") @db.Decimal(12, 2)
  copayment   Decimal?     @db.Decimal(12, 2)
  description String?      @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  deletedAt   DateTime?    @map("deleted_at")

  tenant  Tenant          @relation(fields: [tenantId], references: [id])
  package Package         @relation(fields: [packageId], references: [id])
  usages  CoverageUsage[]

  @@index([tenantId, packageId])
  @@index([tenantId, type])
  @@map("coverages")
}

model Insured {
  id        String        @id @default(uuid()) @db.Uuid
  tenantId  String        @map("tenant_id") @db.Uuid
  curp      String        @db.VarChar(18)
  rfc       String?       @db.VarChar(13)
  fullName  String        @map("full_name") @db.VarChar(160)
  dob       DateTime      @db.Date
  email     String?       @db.VarChar(254)
  phone     String?       @db.VarChar(20)
  /// Cognito sub del insured pool. Nullable hasta que el flow OTP del Sprint 3
  /// popule el campo en el primer login (post-verify). Unique para evitar
  /// que dos insureds compartan identidad federada.
  cognitoSub String?      @unique @map("cognito_sub") @db.VarChar(64)
  packageId String        @map("package_id") @db.Uuid
  validFrom DateTime      @map("valid_from") @db.Date
  validTo   DateTime      @map("valid_to") @db.Date
  status    InsuredStatus @default(active)
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  package       Package         @relation(fields: [packageId], references: [id])
  beneficiaries Beneficiary[]
  certificates  Certificate[]
  claims        Claim[]
  usages        CoverageUsage[]

  @@unique([tenantId, curp], name: "insured_tenant_curp_unique")
  @@index([tenantId, status])
  @@index([tenantId, packageId])
  @@index([tenantId, validTo])
  @@map("insureds")
}

model Beneficiary {
  id           String                  @id @default(uuid()) @db.Uuid
  tenantId     String                  @map("tenant_id") @db.Uuid
  insuredId    String                  @map("insured_id") @db.Uuid
  fullName     String                  @map("full_name") @db.VarChar(160)
  relationship BeneficiaryRelationship
  dob          DateTime                @db.Date
  curp         String?                 @db.VarChar(18)
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")
  deletedAt    DateTime?               @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  insured Insured @relation(fields: [insuredId], references: [id])

  @@index([tenantId, insuredId])
  @@map("beneficiaries")
}

model Certificate {
  id        String            @id @default(uuid()) @db.Uuid
  tenantId  String            @map("tenant_id") @db.Uuid
  insuredId String            @map("insured_id") @db.Uuid
  version   Int               @default(1)
  s3Key     String            @map("s3_key") @db.VarChar(512)
  hash      String            @db.VarChar(128)
  qrPayload String            @map("qr_payload") @db.VarChar(512)
  issuedAt  DateTime          @default(now()) @map("issued_at")
  validTo   DateTime          @map("valid_to") @db.Date
  status    CertificateStatus @default(issued)
  reissueOf String?           @map("reissue_of") @db.Uuid
  reason    String?           @db.Text
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  deletedAt DateTime?         @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  insured Insured @relation(fields: [insuredId], references: [id])

  @@unique([tenantId, insuredId, version], name: "cert_tenant_insured_version_unique")
  @@index([tenantId, insuredId])
  @@index([tenantId, status])
  @@map("certificates")
}

model Claim {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  insuredId       String      @map("insured_id") @db.Uuid
  type            ClaimType
  reportedAt      DateTime    @default(now()) @map("reported_at")
  description     String      @db.Text
  status          ClaimStatus @default(reported)
  amountEstimated Decimal?    @map("amount_estimated") @db.Decimal(12, 2)
  amountApproved  Decimal?    @map("amount_approved") @db.Decimal(12, 2)
  resolvedAt      DateTime?   @map("resolved_at")
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  insured Insured @relation(fields: [insuredId], references: [id])

  @@index([tenantId, insuredId])
  @@index([tenantId, status])
  @@index([tenantId, reportedAt(sort: Desc)])
  @@map("claims")
}

model CoverageUsage {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  insuredId  String   @map("insured_id") @db.Uuid
  coverageId String   @map("coverage_id") @db.Uuid
  usedAt     DateTime @default(now()) @map("used_at")
  amount     Decimal? @db.Decimal(12, 2)
  source     String   @db.VarChar(40)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  insured  Insured  @relation(fields: [insuredId], references: [id])
  coverage Coverage @relation(fields: [coverageId], references: [id])

  @@index([tenantId, insuredId])
  @@index([tenantId, coverageId])
  @@index([tenantId, usedAt(sort: Desc)])
  @@map("coverage_usage")
}

model Batch {
  id          String      @id @default(uuid()) @db.Uuid
  tenantId    String      @map("tenant_id") @db.Uuid
  fileS3Key   String      @map("file_s3_key") @db.VarChar(512)
  fileName    String      @map("file_name") @db.VarChar(255)
  status      BatchStatus @default(validating)
  /// Counters fase VALIDATION (LayoutWorker / sync upload). NO los pisa el
  /// InsuredsCreationWorker — el worker tiene sus propios contadores
  /// (`processedRows`, `successRows`, `failedRows`).
  rowsTotal   Int         @default(0) @map("rows_total")
  rowsOk      Int         @default(0) @map("rows_ok")
  rowsError   Int         @default(0) @map("rows_error")
  /// Counters fase PROCESSING (InsuredsCreationWorker). Se setean en `confirm()`
  /// reseteados a 0 y se incrementan atómicamente por el worker. Cuando
  /// `processedRows >= queuedCount` el batch transiciona a `completed`.
  processedRows Int       @default(0) @map("processed_rows")
  successRows   Int       @default(0) @map("success_rows")
  failedRows    Int       @default(0) @map("failed_rows")
  /// Número real de mensajes encolados al confirmar (puede ser subset de
  /// `rowsOk` si `confirm()` recibió `rowsToInclude`). Comparar contadores
  /// del worker contra esto, NO contra `rowsTotal`.
  queuedCount Int?        @map("queued_count")
  createdBy   String      @map("created_by") @db.Uuid
  startedAt   DateTime?   @map("started_at")
  completedAt DateTime?   @map("completed_at")
  /// Defensa exactly-once para `batch.completed`. Set vía UPDATE atómico
  /// `WHERE completed_event_emitted_at IS NULL`; solo un caller gana la
  /// carrera y emite el evento. UNIQUE index parcial backup en migración.
  completedEventEmittedAt DateTime? @map("completed_event_emitted_at") @db.Timestamptz
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  tenant Tenant       @relation(fields: [tenantId], references: [id])
  errors BatchError[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("batches")
}

model BatchError {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  batchId      String   @map("batch_id") @db.Uuid
  rowNumber    Int      @map("row_number")
  column       String?  @db.VarChar(80)
  errorCode    String   @map("error_code") @db.VarChar(64)
  errorMessage String   @map("error_message") @db.Text
  rawValue     String?  @map("raw_value") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  batch  Batch  @relation(fields: [batchId], references: [id])

  @@index([tenantId, batchId])
  @@map("batch_errors")
}

model EmailEvent {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  certificateId String?        @map("certificate_id") @db.Uuid
  eventType     EmailEventType @map("event_type")
  recipient     String         @db.VarChar(254)
  occurredAt    DateTime       @default(now()) @map("occurred_at")
  detail        Json?
  messageId     String?        @map("message_id") @db.VarChar(255)
  createdAt     DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, certificateId])
  @@index([tenantId, eventType])
  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("email_events")
}

/// S4-06 — Conversación 1:N mensajes entre un insured y el chatbot.
/// Una conversación arranca al primer mensaje del insured (insuredId obligatorio
/// en ese path). El status cambia a `escalated` cuando el matcher no encuentra
/// respuesta y el `EscalationService` deriva al operator. `closed` la setea un
/// cron / endpoint de cierre futuro (Sprint 5+).
model ChatConversation {
  id        String                 @id @default(uuid()) @db.Uuid
  tenantId  String                 @map("tenant_id") @db.Uuid
  insuredId String                 @map("insured_id") @db.Uuid
  status    ChatConversationStatus @default(active)
  createdAt DateTime               @default(now()) @map("created_at")
  updatedAt DateTime               @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  messages ChatMessage[]

  @@index([tenantId, insuredId, status])
  @@index([tenantId, updatedAt(sort: Desc)])
  @@map("chat_conversations")
}

/// S4-06 — Mensaje de chat. Se persisten ambos lados (`role='user'` y
/// `role='bot'`). Cuando el bot responde con un match, `matchedEntryId` apunta
/// a la entry de KB que disparó la respuesta — sirve para feedback (sprint 5+
/// agregaremos `helpful boolean?` al modelo).
///
/// `direction` se conserva por compat con el stub Sprint 1; el path real
/// Sprint 4 usa `role` (user|bot|system). Mapeo:
///   role='user'   → direction='inbound'
///   role='bot'    → direction='outbound'
///   role='system' → direction='outbound' (mensajes ack/derivación)
model ChatMessage {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  insuredId      String?       @map("insured_id") @db.Uuid
  conversationId String?       @map("conversation_id") @db.Uuid
  /// Persistido para compat Sprint 1.
  direction      ChatDirection
  /// Sprint 4: 'user' | 'bot' | 'system'. NULL en filas legacy Sprint 1.
  role           String?       @db.VarChar(16)
  content        String        @db.Text
  intent         String?       @db.VarChar(80)
  confidence     Float?
  escalated      Boolean       @default(false)
  /// FK soft a ChatKb.id (no relation Prisma para que un soft-delete del
  /// entry no rompa el histórico). NULL si no hubo match (fallback / system).
  matchedEntryId String?       @map("matched_entry_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  conversation ChatConversation? @relation(fields: [conversationId], references: [id])

  @@index([tenantId, insuredId])
  @@index([tenantId, conversationId, createdAt])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("chat_messages")
}

/// S4-06 — Knowledge base entry estructurada por categoría.
/// `keywords` y `synonyms` alimentan el matching engine (kb-matcher.service.ts).
/// `priority` desempata cuando 2 entries scorearon igual (mayor primero).
/// `enabled` permite ocultar una entry sin borrarla (admin lo togglea).
model ChatKb {
  id        String       @id @default(uuid()) @db.Uuid
  tenantId  String       @map("tenant_id") @db.Uuid
  category  String       @db.VarChar(80)
  question  String       @db.Text
  answer    String       @db.Text
  /// Tokens canónicos lowercase + sin acentos. El matcher los compara contra
  /// los tokens del mensaje. Ej.: ["poliza","vencimiento","fecha"].
  keywords  String[]     @default([])
  /// Diccionario {tokenCanónico: [sinónimos]}. Ej.:
  ///   {"poliza":["seguro","cobertura"],"vencimiento":["vence","caduca"]}
  synonyms  Json         @default("{}")
  /// Mayor = preferida ante empate. 0 default; admin sube las prioritarias.
  priority  Int          @default(0)
  /// Si false, el matcher la ignora pero el admin sigue viéndola.
  enabled   Boolean      @default(true)
  version   Int          @default(1)
  status    ChatKbStatus @default(draft)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, category])
  @@index([tenantId, status])
  @@index([tenantId, enabled])
  @@map("chat_kb")
}

/// Alertas operativas (P2/P3). En MVP se usa para bounce_rate>5% diario en
/// email — no bloquea envíos, sólo notifica para que ops revise. Modelo
/// deliberadamente simple: no hay multi-tenant por defecto (alertas globales
/// SegurAsist) pero `tenantId` es opcional para alertas tenant-specific.
model SystemAlert {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String?   @map("tenant_id") @db.Uuid
  severity   String    @db.VarChar(16) // 'P1' | 'P2' | 'P3'
  code       String    @db.VarChar(64)
  message    String    @db.Text
  context    Json?
  occurredAt DateTime  @default(now()) @map("occurred_at")
  resolvedAt DateTime? @map("resolved_at")

  @@index([severity, occurredAt(sort: Desc)])
  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("system_alerts")
}

model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  actorId      String?     @map("actor_id") @db.Uuid
  action       AuditAction
  resourceType String      @map("resource_type") @db.VarChar(80)
  resourceId   String?     @map("resource_id") @db.VarChar(80)
  ip           String?     @db.VarChar(45)
  userAgent    String?     @map("user_agent") @db.VarChar(500)
  payloadDiff  Json?       @map("payload_diff")
  traceId      String?     @map("trace_id") @db.VarChar(64)
  occurredAt   DateTime    @default(now()) @map("occurred_at")
  /// Hash chain — `prev_hash` apunta al `row_hash` de la fila anterior por
  /// tenant. La primera fila usa `'0' * 64` como génesis. `row_hash` es
  /// SHA-256 de `prev_hash || tenantId || actorId || action || resourceType
  /// || resourceId || JSON canónico(payloadDiff) || occurredAt.toISOString()`.
  /// Tampering detection: `GET /v1/audit/verify-chain` recomputa la cadena.
  prevHash     String      @map("prev_hash") @db.Char(64)
  rowHash      String      @map("row_hash") @db.Char(64)
  /// Mirror inmutable a S3 (Sprint 2 — S2-07). `mirroredToS3` arranca FALSE;
  /// `AuditS3MirrorService` corre cada minuto, agrupa por (tenant, día), sube
  /// NDJSON al bucket Object Lock COMPLIANCE 730d y marca las filas como
  /// mirrored. Si LocalStack/S3 está down: graceful retry — la fila vuelve a
  /// caer en el batch siguiente (mirrored_to_s3 sigue false hasta success).
  mirroredToS3 Boolean     @default(false) @map("mirrored_to_s3")
  mirroredAt   DateTime?   @map("mirrored_at") @db.Timestamp(3)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([tenantId, resourceType, resourceId])
  @@index([tenantId, actorId])
  @@map("audit_log")
}

/// S3-09 — Job asíncrono de exportación XLSX/PDF de listados (insureds).
///
/// Lifecycle:
///   1. Controller persiste fila con `status='pending'`, encola SQS
///      `reports-queue` y devuelve `{exportId}` al cliente.
///   2. Worker (`ReportsWorkerService`) leee SQS, marca `status='processing'`,
///      genera el archivo, sube a S3 (SSE-KMS), calcula SHA-256, persiste
///      `s3_key`, `hash`, `row_count` y marca `status='ready'`.
///   3. Cliente polea `GET /v1/exports/:id`; cuando `ready`, recibe
///      `downloadUrl` (presigned 24h) + `expiresAt`.
///
/// Anti-abuso (PII):
///   - Rate limit a nivel controller (1/min por user; 10/día por tenant).
///   - Audit log obligatorio en request + completed.
///   - Filename excluye IDs internos (cognito_sub, exportId).
///   - Hash SHA-256 persistido para verificar integridad post-descarga.
///
/// Lectura: el endpoint GET filtra adicionalmente por `requested_by = user.id`
/// (cada user sólo ve sus propios exports). Los superadmins pueden inspeccionar
/// cross-user vía `PrismaBypassRlsService` (no expuesto en MVP).
model Export {
  id          String       @id @db.Uuid
  tenantId    String       @map("tenant_id") @db.Uuid
  requestedBy String       @map("requested_by") @db.Uuid
  /// Tipo de export. En MVP sólo `insureds`. CHECK constraint en migración.
  kind        String       @db.Text
  /// Formato de salida. CHECK constraint en migración (xlsx | pdf).
  format      String       @db.Text
  /// Snapshot inmutable de los filtros aplicados. Reproducibilidad + forensics.
  filters     Json         @default("{}")
  status      ExportStatus @default(pending)
  rowCount    Int?         @map("row_count")
  s3Key       String?      @map("s3_key") @db.Text
  /// SHA-256 hex del archivo final. Permite que el cliente valide integridad
  /// recomputando contra el archivo descargado.
  hash        String?      @db.Text
  error       String?      @db.Text
  requestedAt DateTime     @default(now()) @map("requested_at") @db.Timestamptz(3)
  completedAt DateTime?    @map("completed_at") @db.Timestamptz(3)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status], map: "exports_tenant_status_idx")
  @@index([tenantId, requestedBy, requestedAt(sort: Desc)], map: "exports_requester_idx")
  @@index([tenantId, requestedAt(sort: Desc)], map: "exports_tenant_requested_at_idx")
  @@map("exports")
}

/// S4-04 — Idempotencia DB-side del cron mensual.
///
/// El handler `MonthlyReportsHandler` recibe un mensaje SQS con
/// `{kind: 'cron.monthly_reports', triggeredAt}` y, para cada tenant
/// activo, intenta `prisma.monthlyReportRun.create({...})`. Si la fila
/// ya existe (UNIQUE violation P2002), el handler hace `skip` para ese
/// tenant — esto cubre re-entregas SQS (at-least-once) y re-triggers
/// manuales del cron sin enviar 2 emails.
///
/// `period_year` / `period_month` representan el período REPORTADO (mes
/// anterior al trigger). Ejemplo: trigger 2026-05-01 14:00 UTC → run
/// con `period_year=2026, period_month=4` (reporte de abril).
///
/// `s3_key` se popula cuando el PDF se generó y subió. `email_message_id`
/// guarda el messageId devuelto por SES (o Mailpit en dev) — sirve para
/// correlacionar con `email_events` si en Sprint 5 movemos email tracking
/// al worker dedicado.
///
/// Lifecycle:
///   1. `create({status='pending'})` (idempotency lock).
///   2. Handler genera PDF + sube S3, marca `status='processing'`.
///   3. Envía email via SES, marca `status='completed'` con
///      `s3_key`, `email_message_id`, `recipient_count`, `completed_at`.
///   4. Si cualquier paso falla → `status='failed'` con `error_message`,
///      `completed_at` set. La UNIQUE evita reintento automático.
///
/// RLS: tenant-scoped. La política sigue el patrón estándar
/// (`tenant_id::text = current_setting('app.current_tenant', true)`).
/// El handler corre con BYPASSRLS (worker application-scoped, sin `req`),
/// igual que ReportsWorker — documentado en ADR-0001.
model MonthlyReportRun {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  /// Año del período REPORTADO (mes anterior al trigger).
  periodYear      Int                 @map("period_year")
  /// Mes del período (1..12) — CHECK constraint en migración.
  periodMonth     Int                 @map("period_month")
  status          MonthlyReportStatus @default(pending)
  /// S3 key del PDF generado (`monthly-reports/{tenantId}/{year}-{mm}.pdf`).
  s3Key           String?             @map("s3_key") @db.Text
  /// Cantidad de destinatarios al momento del envío (snapshot del env var).
  recipientCount  Int?                @map("recipient_count")
  /// MessageId devuelto por SES/Mailpit. NULL si el envío no se hizo.
  emailMessageId  String?             @map("email_message_id") @db.Text
  /// Mensaje de error legible si `status='failed'` (truncado a 500 chars).
  errorMessage    String?             @map("error_message") @db.Text
  /// Trigger source — `eventbridge` (cron real) o `manual` (re-trigger ops).
  triggeredBy     String              @default("eventbridge") @map("triggered_by") @db.VarChar(32)
  triggeredAt     DateTime            @default(now()) @map("triggered_at") @db.Timestamptz(3)
  completedAt     DateTime?           @map("completed_at") @db.Timestamptz(3)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  /// IDEMPOTENCIA — UNIQUE natural key. Cualquier 2do `create` con la misma
  /// terna lanza P2002, que el handler interpreta como "ya procesado, skip".
  @@unique([tenantId, periodYear, periodMonth], name: "monthly_report_run_period_unique")
  @@index([tenantId, triggeredAt(sort: Desc)], map: "monthly_report_runs_tenant_triggered_idx")
  @@index([status, triggeredAt(sort: Desc)], map: "monthly_report_runs_status_idx")
  @@map("monthly_report_runs")
}
