# Copy to terraform.tfvars and fill values. NEVER commit terraform.tfvars.

environment   = "staging"
aws_region    = "mx-central-1"
aws_dr_region = "us-east-1"

vpc_cidr       = "10.20.0.0/16"
domain_name    = "segurasist.app"
domain_zone_id = "ZXXXXXXXXXXXXXXXXXX"

github_oauth_token_secret_arn = "arn:aws:secretsmanager:mx-central-1:222222222222:secret:segurasist/github/amplify-oauth-XXXXXX"

image_tag_api = "bootstrap-placeholder"

# G-1 Sprint 5 iter 2 — DR drill OIDC role (módulo dr-drill-iam).
# Output `oidc_provider_arns["staging"]` de `global/iam-github-oidc`.
github_oidc_provider_arn = "arn:aws:iam::222222222222:oidc-provider/token.actions.githubusercontent.com"
github_org               = "segurasist"
github_repo              = "segurasist"
