# Copy to terraform.tfvars and fill values. NEVER commit terraform.tfvars.

environment   = "dev"
aws_region    = "mx-central-1"
aws_dr_region = "us-east-1"

vpc_cidr       = "10.10.0.0/16"
domain_name    = "segurasist.app"
domain_zone_id = "ZXXXXXXXXXXXXXXXXXX"

# Pre-existing Secrets Manager secret containing the GitHub PAT/OAuth token (key "token")
# Created out-of-band; never store the token value here.
github_oauth_token_secret_arn = "arn:aws:secretsmanager:mx-central-1:111111111111:secret:segurasist/github/amplify-oauth-XXXXXX"

image_tag_api = "bootstrap-placeholder"
