{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyDeleteObjectLockConfiguration",
      "Effect": "Deny",
      "Action": [
        "s3:PutBucketObjectLockConfiguration",
        "s3:BypassGovernanceRetention"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:PrincipalArn": [
            "arn:aws:iam::*:role/AWSReservedSSO_AdminFullAccess_*"
          ]
        }
      }
    },
    {
      "Sid": "DenyDeleteObjectsUnderRetention",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteObjectVersion",
        "s3:DeleteObjectVersionTagging"
      ],
      "Resource": "*",
      "Condition": {
        "Bool": {
          "s3:object-lock-mode": "true"
        }
      }
    }
  ]
}
